#!/bin/sh
set -e

# Match the prefix postinst used (derive it from where the daemon landed).
if [ -x /var/jb/usr/bin/ioscpyd ]; then
    PREFIX=/var/jb
elif [ -n "$JBROOT" ] && [ -x "$JBROOT/usr/bin/ioscpyd" ]; then
    PREFIX="$JBROOT"
elif command -v jbroot >/dev/null 2>&1 && [ -d "$(jbroot / 2>/dev/null)/Library/LaunchDaemons" ]; then
    PREFIX="$(jbroot / 2>/dev/null)"
    PREFIX="${PREFIX%/}"
else
    PREFIX=""
fi

PLIST="$PREFIX/Library/LaunchDaemons/com.ioscpy.daemon.plist"

launchctl bootout system "$PLIST" 2>/dev/null || launchctl unload "$PLIST" 2>/dev/null || true
rm -f "$PLIST"
rm -f /var/mobile/Library/Preferences/com.ioscpy.hook.loaded

exit 0
